<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>BeelzeMail Ads</title>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI',sans-serif;background:#f5f5f5;min-height:100vh;padding:20px}
  .container{max-width:820px;margin:0 auto}
  .header{display:flex;align-items:center;gap:10px;margin-bottom:22px;padding-bottom:16px;border-bottom:2px solid #111}
  .header h1{font-size:1.5rem;font-weight:800;color:#111;letter-spacing:-0.5px}
  .header span{font-size:0.8rem;color:#888;font-weight:400}
  .card{background:#fff;border:2px solid #111;border-radius:10px;padding:20px;margin-bottom:16px}
  .card h2{font-size:0.9rem;font-weight:700;color:#111;margin-bottom:14px;display:flex;align-items:center;gap:7px;text-transform:uppercase;letter-spacing:0.5px}
  .card h2 svg{width:15px;height:15px;color:#111}
  label{display:block;font-size:0.78rem;font-weight:600;color:#333;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.3px}
  input,select,textarea{width:100%;border:2px solid #ddd;border-radius:7px;padding:9px 11px;font-size:0.88rem;outline:none;transition:border 0.15s;background:#fff;color:#111}
  input:focus,select:focus,textarea:focus{border-color:#111}
  textarea{resize:vertical;min-height:90px;line-height:1.5}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  .field{margin-bottom:12px}

  /* Email tags - VERTICAL list */
  .email-list{border:2px solid #ddd;border-radius:7px;background:#fff;max-height:220px;overflow-y:auto}
  .email-list:focus-within{border-color:#111}
  .email-item{display:flex;align-items:center;justify-content:space-between;padding:7px 11px;border-bottom:1px solid #f0f0f0;font-size:0.85rem;color:#111}
  .email-item:last-child{border-bottom:none}
  .email-item button{background:none;border:none;cursor:pointer;color:#999;display:flex;align-items:center;padding:2px}
  .email-item button:hover{color:#111}
  .email-input-row{display:flex;gap:8px;margin-bottom:8px}
  .email-input-row input{flex:1;margin:0}
  .email-input-row button{background:#111;color:#fff;border:2px solid #111;border-radius:7px;padding:0 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;display:flex;align-items:center;gap:5px}
  .email-input-row button:hover{background:#333}
  .count-badge{display:inline-flex;align-items:center;gap:4px;background:#111;color:#fff;border-radius:4px;padding:2px 8px;font-size:0.75rem;font-weight:700;margin-left:8px}

  /* Mode buttons */
  .mode-btns{display:flex;gap:8px}
  .mode-btn{flex:1;padding:9px;border:2px solid #ddd;border-radius:7px;background:#fff;cursor:pointer;font-size:0.85rem;font-weight:600;color:#666;transition:all 0.15s}
  .mode-btn.active{border-color:#111;background:#111;color:#fff}

  /* Domains */
  .domain-row{display:flex;gap:8px;margin-bottom:10px;align-items:flex-end}
  .domain-row .field{flex:1;margin:0}
  .domain-row button{background:#111;color:#fff;border:2px solid #111;border-radius:7px;padding:9px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;white-space:nowrap;height:38px;display:flex;align-items:center;gap:5px}
  .domain-row button:hover{background:#333}
  .domain-list{display:flex;flex-direction:column;gap:6px;margin-top:6px}
  .domain-chip{background:#f5f5f5;border:2px solid #e0e0e0;border-radius:7px;padding:7px 12px;font-size:0.85rem;display:flex;align-items:center;justify-content:space-between;gap:8px}
  .domain-chip a{color:#0057ff;text-decoration:underline;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
  .domain-chip button{background:none;border:none;cursor:pointer;color:#999;display:flex;align-items:center;flex-shrink:0}
  .domain-chip button:hover{color:#111}

  /* Images */
  .img-upload-area{border:2px dashed #bbb;border-radius:8px;padding:22px;text-align:center;cursor:pointer;transition:all 0.15s;background:#fafafa}
  .img-upload-area:hover{border-color:#111;background:#f0f0f0}
  .img-upload-area svg{width:30px;height:30px;color:#555;margin-bottom:8px}
  .img-upload-area p{color:#555;font-size:0.88rem}
  .img-upload-area input{display:none}
  .img-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:10px;margin-top:12px}
  .img-card{border:2px solid #ddd;border-radius:8px;overflow:hidden;background:#f5f5f5;position:relative}
  .img-card img{width:100%;height:90px;object-fit:cover;display:block}
  .img-card .img-info{padding:6px 8px;font-size:0.72rem;color:#555;word-break:break-all;line-height:1.3}
  .img-card .rm-btn{position:absolute;top:5px;right:5px;background:#111;border:none;border-radius:50%;width:22px;height:22px;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center}
  .img-card .rm-btn svg{width:12px;height:12px}
  .uploading-msg{display:flex;align-items:center;gap:6px;font-size:0.82rem;color:#555;margin-top:8px}

  /* Generate button */
  .gen-btn{width:100%;padding:13px;background:#111;color:#fff;border:2px solid #111;border-radius:9px;font-size:0.95rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;transition:opacity 0.15s;letter-spacing:0.3px}
  .gen-btn:hover{opacity:0.85}
  .gen-btn svg{width:17px;height:17px}

  /* Code output */
  .code-wrap{background:#0f172a;border:2px solid #111;border-radius:10px;margin-top:16px;overflow:hidden}
  .code-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid #1e293b}
  .code-header span{color:#94a3b8;font-size:0.82rem;font-weight:600;display:flex;align-items:center;gap:6px}
  .code-header span svg{width:14px;height:14px}
  .copy-btn{background:#1e293b;color:#94a3b8;border:1px solid #334155;border-radius:6px;padding:6px 14px;cursor:pointer;font-size:0.8rem;font-weight:600;display:flex;align-items:center;gap:6px;transition:all 0.15s}
  .copy-btn:hover{background:#334155;color:#fff}
  .copy-btn svg{width:13px;height:13px}
  .copy-btn.copied{background:#166534;color:#bbf7d0;border-color:#166534}
  pre.code-box{color:#e2e8f0;font-family:'Courier New',monospace;font-size:0.78rem;padding:18px;overflow-x:auto;white-space:pre;line-height:1.65;margin:0}

  .hint{font-size:0.74rem;color:#999;margin-top:4px}
</style>
</head>
<body>
<div class="container">






<!-- LOCK SCREEN -->
<div id="lockScreen" style="position:fixed;inset:0;background:#fff;z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px">
  <img src="https://media.base44.com/images/public/69aeee89baab381c29ae8d31/bb2a57956_Screenshot_20260406_015157_Gallery.jpg" style="width:72px;height:72px;border-radius:14px;object-fit:cover;border:2px solid #111"/>
  <h1 style="font-size:1.4rem;font-weight:800;color:#111;letter-spacing:-0.5px">BeelzeMail Ads</h1>
  <p style="font-size:0.78rem;color:#888;font-weight:500">by Beelze</p>
  <div style="display:flex;flex-direction:column;gap:10px;width:260px;margin-top:8px">
    <div style="position:relative">
      <input id="lockInput" type="password" placeholder="Enter password" maxlength="20"
        style="width:100%;border:2px solid #ddd;border-radius:8px;padding:10px 40px 10px 12px;font-size:0.9rem;outline:none"
        onfocus="this.style.borderColor='#111'" onblur="this.style.borderColor='#ddd'"
        onkeydown="if(event.key==='Enter') unlockApp()"/>
      <span id="toggleEye" onclick="togglePwd()" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);cursor:pointer;color:#999">
        <i data-lucide="eye-off" style="width:16px;height:16px"></i>
      </span>
    </div>
    <p id="lockError" style="color:#dc2626;font-size:0.78rem;text-align:center;display:none">❌ Wrong password. Try again.</p>
    <button onclick="unlockApp()" style="background:#111;color:#fff;border:none;border-radius:8px;padding:11px;font-size:0.88rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px">
      <i data-lucide="lock-open" style="width:15px;height:15px"></i> Unlock
    </button>
  </div>
</div>





  <!-- Header -->
<div class="header">
    <img src="https://media.base44.com/images/public/69aeee89baab381c29ae8d31/bb2a57956_Screenshot_20260406_015157_Gallery.jpg" style="width:38px;height:38px;border-radius:8px;object-fit:cover;border:0px solid #FFFFFF"/>
    <div>
      <h1>BeelzeMail Ads <span>by Beelze</span></h1>
    </div>
  </div>

  <!-- SMTP Config -->
  <div class="card">
    <h2><i data-lucide="settings-2"></i> SMTP Config</h2>
    <div class="grid2">
      <div class="field"><label>Sender Email</label><input id="senderEmail" value="beelzeapps@gmail.com"/></div>
      <div class="field"><label>App Password</label><input id="senderPass" type="password" placeholder="No spaces"/></div>
      <div class="field"><label>SMTP Host</label><input id="smtpHost" value="smtp.gmail.com"/></div>
      <div class="field"><label>SMTP Port</label><input id="smtpPort" value="587"/></div>
    </div>
  </div>

  <!-- Email Details -->
  <div class="card">
    <h2><i data-lucide="send"></i> Email Settings</h2>
    <div class="field"><label>Subject</label><input id="subject" placeholder="e.g. Good day from Beelze Ads"/></div>
    <div class="field">
      <label>Send Mode</label>
      <div class="mode-btns">
        <button class="mode-btn active" onclick="setMode('bcc',this)">BCC</button>
        <button class="mode-btn" onclick="setMode('cc',this)">CC</button>
        <button class="mode-btn" onclick="setMode('to',this)">TO</button>
      </div>
    </div>
    <div class="field"><label>Delay (seconds)</label><input id="delay" value="1.5" type="number" step="0.5"/></div>
  </div>

  <!-- Recipients -->
  <div class="card">
    <h2><i data-lucide="users"></i> Recipients <span class="count-badge" id="countBadge">0</span></h2>
    <div class="email-input-row">
      <input id="emailInput" placeholder="Paste emails separated by commas, or type one and press Add"/>
      <button onclick="addEmailsFromInput()"><i data-lucide="plus"></i> Add</button>
    </div>
    <p class="hint">Paste multiple: email1@x.com, email2@x.com, ... then click Add</p>
    <div class="email-list" id="emailList"><div style="padding:12px;color:#aaa;font-size:0.82rem;text-align:center">No emails added yet</div></div>
  </div>

  <!-- Message Body -->
  <div class="card">
    <h2><i data-lucide="file-text"></i> Email Body</h2>
    <div class="field"><label>Message (use {name} for personalisation)</label>
      <textarea id="bodyMsg" rows="6" placeholder="Hello {name},&#10;&#10;Your message here.&#10;&#10;Best,&#10;Beelze Ads"></textarea>
    </div>
    <div class="field"><label>Sender Sign-off Name</label><input id="senderName" placeholder="e.g. Beelze Ads"/></div>
  </div>

  <!-- Clickable Links -->
  <div class="card">
    <h2><i data-lucide="link-2"></i> Clickable Links in Email</h2>
    <div class="domain-row">
      <div class="field"><label>Label</label><input id="domainText" placeholder="e.g. Visit our store"/></div>
      <div class="field" style="flex:2"><label>URL</label><input id="domainUrl" placeholder="https://darkmasterstore.co.za"/></div>
      <button onclick="addDomain()"><i data-lucide="plus"></i> Add</button>
    </div>
    <div class="domain-list" id="domainList"></div>
  </div>

  <!-- Images -->
  <div class="card">
    <h2><i data-lucide="image"></i> Images (ImgBB Upload)</h2>
    <div class="img-upload-area" onclick="document.getElementById('imgInput').click()">
      <i data-lucide="upload-cloud"></i>
      <p>Click to upload images — they go directly to ImgBB</p>
      <input type="file" id="imgInput" accept="image/*" multiple onchange="uploadImages(this.files)"/>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:10px;align-items:flex-end">
      <div style="flex:1"><label>Or paste image URL directly</label>
        <input id="directImgUrl" placeholder="https://i.ibb.co/yourimage.jpg"/></div>
      <button onclick="addDirectUrl()" style="background:#111;color:#fff;border:2px solid #111;border-radius:7px;padding:9px 14px;cursor:pointer;font-size:0.82rem;font-weight:600;height:38px;display:flex;align-items:center;gap:5px"><i data-lucide="link"></i> Add URL</button>
    </div>
    <div id="uploadStatus"></div>
    <div class="img-grid" id="imgGrid"></div>
  </div>

  <!-- Generate -->
  <button class="gen-btn" onclick="generate()">
    <i data-lucide="code-2"></i> Generate Python Code
  </button>

  <!-- Output -->
  <div id="outputSection" style="display:none">
    <div class="code-wrap">
      <div class="code-header">
        <span><i data-lucide="terminal"></i> Generated Python Script</span>
        <button class="copy-btn" id="copyBtn" onclick="copyCode()">
          <i data-lucide="copy"></i> Copy All
        </button>
      </div>
      <pre class="code-box" id="codeOutput"></pre>
    </div>
  </div>

</div>

<script>
function initIcons(){ if(typeof lucide !== 'undefined') lucide.createIcons(); }
initIcons();



// Lock screen
initIcons();
document.getElementById('lockInput').focus();

function unlockApp(){
  const val = document.getElementById('lockInput').value;
  if(val === 'VNAXXTTM'){
    document.getElementById('lockScreen').style.display='none';
  } else {
    document.getElementById('lockError').style.display='block';
    document.getElementById('lockInput').value='';
    document.getElementById('lockInput').focus();
  }
}

function togglePwd(){
  const inp = document.getElementById('lockInput');
  const icon = document.getElementById('toggleEye');
  if(inp.type === 'password'){
    inp.type = 'text';
    icon.innerHTML = '<i data-lucide="eye" style="width:16px;height:16px"></i>';
  } else {
    inp.type = 'password';
    icon.innerHTML = '<i data-lucide="eye-off" style="width:16px;height:16px"></i>';
  }
  initIcons();
}



let sendMode = 'bcc';
let emails = [];
let domains = [];
let uploadedImages = [];
const IMGBB_API_KEY = '7582cc8e40651016b8391c34b4216727';

// Mode
function setMode(m, btn){
  sendMode = m;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

// Emails - VERTICAL list
function addEmailsFromInput(){
  const raw = document.getElementById('emailInput').value;
  const parts = raw.split(/[\n,]+/).map(e=>e.trim()).filter(e=>e.includes('@'));
  parts.forEach(e => { if(!emails.includes(e)) emails.push(e); });
  document.getElementById('emailInput').value = '';
  renderEmails();
}
document.getElementById('emailInput').addEventListener('keydown', e => {
  if(e.key === 'Enter'){ e.preventDefault(); addEmailsFromInput(); }
});
function removeEmail(i){ emails.splice(i,1); renderEmails(); }
function renderEmails(){
  const el = document.getElementById('emailList');
  if(emails.length === 0){
    el.innerHTML = '<div style="padding:12px;color:#aaa;font-size:0.82rem;text-align:center">No emails added yet</div>';
  } else {
    el.innerHTML = emails.map((e,i) => `
      <div class="email-item">
        <span>${e}</span>
        <button onclick="removeEmail(${i})" title="Remove"><i data-lucide="x" style="width:14px;height:14px"></i></button>
      </div>`).join('');
  }
  document.getElementById('countBadge').textContent = emails.length;
  initIcons();
}

// Domains
function addDomain(){
  const text = document.getElementById('domainText').value.trim();
  const url  = document.getElementById('domainUrl').value.trim();
  if(!url) return;
  domains.push({text: text||url, url});
  document.getElementById('domainText').value='';
  document.getElementById('domainUrl').value='';
  renderDomains();
}
function removeDomain(i){ domains.splice(i,1); renderDomains(); }
function renderDomains(){
  document.getElementById('domainList').innerHTML = domains.map((d,i) =>
    `<div class="domain-chip">
      <a href="${d.url}" target="_blank">${d.text} — ${d.url}</a>
      <button onclick="removeDomain(${i})"><i data-lucide="x" style="width:14px;height:14px"></i></button>
    </div>`
  ).join('');
initIcons();
}



function addDirectUrl(){
  const url = document.getElementById('directImgUrl').value.trim();
  if(!url) return;
  const idx = uploadedImages.length;
  uploadedImages.push({name:'direct', url});
  addImgCard(url, 'direct', idx);
  document.getElementById('directImgUrl').value='';
}





// ImgBB Upload
async function uploadImages(files){
  const status = document.getElementById('uploadStatus');
  for(const file of files){
    status.innerHTML = `<div class="uploading-msg"><i data-lucide="loader" style="width:14px;height:14px"></i> Uploading ${file.name}...</div>`;
    initIcons();
    const form = new FormData();
    form.append('image', file);
    try {
      const res = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_API_KEY}`, {method:'POST', body:form});
      const data = await res.json();
      if(data.success){
        const url = data.data.url;
        const idx = uploadedImages.length;
        uploadedImages.push({name: file.name, url});
        addImgCard(url, file.name, idx);
        status.innerHTML = `<div class="uploading-msg" style="color:#16a34a"><i data-lucide="check-circle" style="width:14px;height:14px"></i> ${file.name} uploaded!</div>`;
      } else {
        status.innerHTML = `<div class="uploading-msg" style="color:#dc2626"><i data-lucide="x-circle" style="width:14px;height:14px"></i> Upload failed</div>`;
      }
    } catch(err) {
      status.innerHTML = `<div class="uploading-msg" style="color:#dc2626"><i data-lucide="x-circle" style="width:14px;height:14px"></i> Error: ${err.message}</div>`;
    }
    initIcons();
  }
  document.getElementById('imgInput').value='';
}
function addImgCard(url, name, idx){
  const grid = document.getElementById('imgGrid');
  const div = document.createElement('div');
  div.className = 'img-card';
  div.id = 'imgcard_'+idx;
  div.innerHTML = `
    <button class="rm-btn" onclick="removeImg(${idx})"><i data-lucide="x"></i></button>
    <img src="${url}" alt="${name}"/>
    <div class="img-info">🔗 ${url}</div>`;
  grid.appendChild(div);
  initIcons();
}
function removeImg(i){
  uploadedImages[i] = null;
  const el = document.getElementById('imgcard_'+i);
  if(el) el.remove();
}

// Generate Python Code
function generate(){
  const senderEmail = document.getElementById('senderEmail').value.trim();
  const senderPass  = document.getElementById('senderPass').value.trim();
  const smtpHost    = document.getElementById('smtpHost').value.trim();
  const smtpPort    = document.getElementById('smtpPort').value.trim();
  const subject     = document.getElementById('subject').value.trim() || 'Hello from Beelze Ads';
  const delay       = document.getElementById('delay').value.trim() || '1.5';
  const bodyMsg     = document.getElementById('bodyMsg').value.trim() || 'Hello {name},\n\nYour message here.';
  const senderName  = document.getElementById('senderName').value.trim() || 'Beelze Ads';

  const recipientsCode = emails.map(e => `    {"email": "${e}", "name": "Friend"},`).join('\n');

  const imgHtml = uploadedImages.filter(Boolean).map(img =>
    `  <img src="${img.url}" alt="image" style="max-width:100%;margin:10px 0;border-radius:8px;"/>`
  ).join('\n');

  const domainHtml = domains.map(d =>
    `  <p><a href="${d.url}" target="_blank" style="color:#0057ff;text-decoration:underline;font-weight:600;">${d.text}</a></p>`
  ).join('\n');

  const bodyLines = bodyMsg.split('\n').map(l => `  <p>${l}</p>`).join('\n');

  const htmlBody = `<html><body>

${bodyLines}
${imgHtml}
${domainHtml}
  <p>Best,<br/>${senderName}</p>
</body></html>`;

  const textBody = bodyMsg + `\n\nBest,\n${senderName}`;

  const code = `#!/usr/bin/env python3
import smtplib, ssl, time, os
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from email.mime.base import MIMEBase
from email import encoders

# ── CONFIG ──────────────────────────────────
SENDER_EMAIL    = "${senderEmail}"
SENDER_PASSWORD = "${senderPass}"
SMTP_HOST       = "${smtpHost}"
SMTP_PORT       = ${smtpPort}

SUBJECT   = "${subject}"
SEND_MODE = "${sendMode}"
DELAY     = ${delay}

BODY_HTML = """
${htmlBody}
"""

BODY_TEXT = """${textBody}"""

ATTACHMENT_PATH = None

# ── RECIPIENTS ──────────────────────────────
RECIPIENTS = [
${recipientsCode}
]

# ── SEND ────────────────────────────────────
def build_msg(recipient, bcc_list=None):
    msg = MIMEMultipart("alternative")
    msg["From"]    = SENDER_EMAIL
    msg["Subject"] = SUBJECT
    name = recipient.get("name", "Friend")

    if SEND_MODE == "bcc":
        msg["To"]  = SENDER_EMAIL
        # NOTE: Do NOT add Bcc header — pass emails only to sendmail() to hide recipients
    elif SEND_MODE == "cc":
        msg["To"]  = recipient["email"]
        if bcc_list: msg["Cc"] = ", ".join(bcc_list)
    else:
        msg["To"] = recipient["email"]

    msg.attach(MIMEText(BODY_TEXT.format(name=name), "plain"))
    msg.attach(MIMEText(BODY_HTML.format(name=name), "html"))

    if ATTACHMENT_PATH and os.path.exists(ATTACHMENT_PATH):
        with open(ATTACHMENT_PATH, "rb") as f:
            part = MIMEBase("application", "octet-stream")
            part.set_payload(f.read())
        encoders.encode_base64(part)
        part.add_header("Content-Disposition", f"attachment; filename={os.path.basename(ATTACHMENT_PATH)}")
        msg.attach(part)
    return msg

def main():
    ctx = ssl.create_default_context()
    print(f"Connecting to {SMTP_HOST}:{SMTP_PORT}...")
    with smtplib.SMTP(SMTP_HOST, SMTP_PORT) as s:
        s.starttls(context=ctx)
        s.login(SENDER_EMAIL, SENDER_PASSWORD)
        print(f"Logged in. Sending to {len(RECIPIENTS)} recipients via {SEND_MODE.upper()}...\\n")

        if SEND_MODE == "bcc":
            emails = [r["email"] for r in RECIPIENTS]
            msg = build_msg(RECIPIENTS[0])
            s.sendmail(SENDER_EMAIL, emails, msg.as_string())
            print(f"\\u2713 BCC email sent to {len(emails)} recipients.")
        else:
            for i, r in enumerate(RECIPIENTS, 1):
                msg = build_msg(r)
                s.sendmail(SENDER_EMAIL, [r["email"]], msg.as_string())
                print(f"[{i}/{len(RECIPIENTS)}] Sent \\u2192 {r['email']}")
                if i < len(RECIPIENTS): time.sleep(DELAY)

    print("\\n\\u2705 Done!")

if __name__ == "__main__":
    main()`;

  document.getElementById('codeOutput').textContent = code;
  document.getElementById('outputSection').style.display = 'block';
  document.getElementById('outputSection').scrollIntoView({behavior:'smooth'});
  initIcons();
}

function copyCode(){
  const code = document.getElementById('codeOutput').textContent;
  navigator.clipboard.writeText(code);
  const btn = document.getElementById('copyBtn');
  btn.classList.add('copied');
  btn.innerHTML = '<i data-lucide="check"></i> Copied!';
  initIcons();
  setTimeout(()=>{
    btn.classList.remove('copied');
    btn.innerHTML = '<i data-lucide="copy"></i> Copy All';
    initIcons();
  }, 2500);
}
